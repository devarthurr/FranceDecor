@model List<Produto>
<!DOCTYPE html>
<html>
<head>
    <title>France Decor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .card-img-top { height: 250px; object-fit: contain; padding: 10px; }
        .navbar { background: #0047BB; border-bottom: 4px solid #D4AF37; }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark mb-4">
        <div class="container text-white fw-bold">FRANCE DECOR</div>
    </nav>
    <div class="container">
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var p in Model) {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 15px;">
                        <img src="@p.Imagens[0]" class="card-img-top">
                        <div class="card-body text-center">
                            <h5 class="fw-bold">@p.Nome</h5>
                            <p class="text-primary fw-bold">R$ @p.Preco.ToString("N2")</p>
                            <a href="/produto/@p.Id" class="btn btn-outline-primary w-100 rounded-pill">Ver Detalhes</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</body>
</html>